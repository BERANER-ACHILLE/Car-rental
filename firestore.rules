rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to verify if the request is from the owner of the user ID
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper to validate a user profile structure
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'phone'])
        && data.fullName is string 
        && data.email is string 
        && data.phone is string;
    }

    // Match user profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Match bookings
    match /bookings/{bookingId} {
      allow create: if true; // Both authenticated and guest users can create booking requests
      allow read: if request.auth != null && (
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid
      );
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
